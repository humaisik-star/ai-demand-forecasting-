# Azure OpenAI / AI Foundry configuration for assistant.py
# Copy this file to `.env` and fill in the values from your Azure resource.

# The endpoint of your Azure OpenAI resource, e.g. https://my-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# API key (Keys and Endpoint blade in the Azure portal)
AZURE_OPENAI_API_KEY=

# The *deployment name* you gave your chat model (NOT the base model name),
# e.g. gpt-4o, gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT=

# API version (optional; a recent default is set in code)
AZURE_OPENAI_API_VERSION=2024-10-21

# Embedding deployment for the RAG layer (build_kb.py, bilgi_ara)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
